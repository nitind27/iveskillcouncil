# Copy this file to .env and update with your actual credentials

# Database Connection
# Format: mysql://username:password@host:port/database_name
# Example: mysql://root:mypassword@localhost:3306/franchise_institute
DATABASE_URL="mysql://root:@localhost:3306/franchise_institute"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# JWT Secrets (IMPORTANT: Change these in production!)
# Generate strong random strings (minimum 32 characters)
JWT_ACCESS_SECRET="franchise-institute-access-secret-key-2024-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="franchise-institute-refresh-secret-key-2024-change-in-production-min-32-chars"

# Email Configuration (Optional - for future use)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Optional: Redis for production caching
# REDIS_URL="redis://localhost:6379"

# Optional: CDN URL
# CDN_URL="https://cdn.yourdomain.com"

