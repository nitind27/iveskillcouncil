// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp

  users         User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  key         String   @unique @db.VarChar(100)
  label       String   @db.VarChar(150)
  module      String   @db.VarChar(80)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  rolePermissions RolePermission[]
  planPermissions  PlanPermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int   @id @default(autoincrement()) @db.UnsignedInt
  roleId       Int   @map("role_id") @db.UnsignedTinyInt
  permissionId Int   @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "unique_role_permission")
  @@index([permissionId], map: "idx_role_perm_permission")
  @@map("role_permissions")
}

model PlanPermission {
  id           Int   @id @default(autoincrement()) @db.UnsignedInt
  planId       Int   @map("plan_id") @db.UnsignedTinyInt
  permissionId Int   @map("permission_id") @db.UnsignedInt

  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  permission Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([planId, permissionId], map: "unique_plan_permission")
  @@index([permissionId], map: "idx_plan_perm_permission")
  @@map("plan_permissions")
}

model User {
  id                 BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  roleId             Int      @map("role_id") @db.UnsignedTinyInt
  franchiseId        BigInt?  @map("franchise_id") @db.UnsignedBigInt
  fullName           String   @map("full_name") @db.VarChar(150)
  email              String   @unique @db.VarChar(150)
  phone              String?  @unique @db.VarChar(20)
  password           String   @db.VarChar(255)
  mustChangePassword Boolean  @default(false) @map("must_change_password") @db.TinyInt
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamp

  role      Role      @relation(fields: [roleId], references: [id])
  franchise Franchise? @relation(fields: [franchiseId], references: [id])
  
  ownedFranchises Franchise[] @relation("FranchiseOwner")
  attendance      Attendance[]
  staff           Staff?
  student         Student?
  issuedCertificates Certificate[] @relation("CertificateIssuer")
  announcements   Announcement[] @relation("AnnouncementCreator")

  @@index([roleId], map: "idx_role")
  @@index([franchiseId], map: "idx_franchise")
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model SubscriptionPlan {
  id            Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  name          PlanType @unique
  price         Decimal  @db.Decimal(10, 2)
  durationInDays Int    @map("duration_in_days")
  status        PlanStatus @default(ACTIVE)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp

  franchises     Franchise[]
  planPermissions PlanPermission[]
  franchiseOrders FranchiseOrder[]
  franchiseApplications FranchiseApplication[]

  @@map("subscription_plans")
}

enum PlanType {
  SILVER
  GOLD
  DIAMOND
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

model Franchise {
  id              BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name            String        @db.VarChar(150)
  slug            String?       @unique @db.VarChar(100)
  ownerId         BigInt        @map("owner_id") @db.UnsignedBigInt
  planId          Int           @map("plan_id") @db.UnsignedTinyInt
  subscriptionStart DateTime     @map("subscription_start") @db.Date
  subscriptionEnd   DateTime     @map("subscription_end") @db.Date
  address         String?       @db.Text
  city            String?       @db.VarChar(100)
  state           String?       @db.VarChar(100)
  pincode         String?       @db.VarChar(20)
  phone           String?       @db.VarChar(20)
  email           String?       @db.VarChar(150)
  status          FranchiseStatus @default(PENDING)
  rejectionReason String?       @map("rejection_reason") @db.VarChar(500)
  // Custom panel config (JSON: logoUrl, primaryColor, siteName, tagline, etc.)
  panelConfig     Json?         @map("panel_config") @db.Json
  // Application reference
  applicationId   BigInt?       @unique @map("application_id") @db.UnsignedBigInt
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp

  owner           User          @relation("FranchiseOwner", fields: [ownerId], references: [id])
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  application     FranchiseApplication? @relation(fields: [applicationId], references: [id])
  users           User[]
  students        Student[]
  staff           Staff[]
  courses         FranchiseCourseFee[]
  ownedCourses    Course[]      @relation("FranchiseCourses")
  attendance      Attendance[]
  certificates    Certificate[]
  feedback        Feedback[]
  payments        Payment[]

  @@index([ownerId], map: "idx_owner")
  @@index([planId], map: "idx_plan")
  @@index([slug], map: "idx_franchise_slug")
  @@map("franchises")
}

enum FranchiseStatus {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
}

model FranchiseApplication {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  // Applicant info
  fullName          String    @map("full_name") @db.VarChar(150)
  email             String    @db.VarChar(150)
  phone             String    @db.VarChar(20)
  alternatPhone     String?   @map("alternate_phone") @db.VarChar(20)
  // Business info
  instituteName     String    @map("institute_name") @db.VarChar(200)
  businessType      String    @map("business_type") @db.VarChar(50)
  // Address
  address           String    @db.VarChar(500)
  city              String    @db.VarChar(100)
  state             String    @db.VarChar(100)
  pincode           String    @db.VarChar(20)
  // KYC Documents (stored as JSON array of {type, url, name})
  documents         Json?     @db.Json
  // Status
  status            String    @default("PENDING") @db.VarChar(30)
  adminNotes        String?   @map("admin_notes") @db.Text
  reviewedBy        BigInt?   @map("reviewed_by") @db.UnsignedBigInt
  reviewedAt        DateTime? @map("reviewed_at") @db.DateTime
  // Plan preference
  planId            Int?      @map("plan_id") @db.UnsignedTinyInt
  // Message
  message           String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp

  franchise         Franchise?
  plan              SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@index([email], map: "idx_app_email")
  @@index([status], map: "idx_app_status")
  @@map("franchise_applications")
}

model CourseCategory {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  icon        String?  @db.VarChar(50)
  colorClass  String?  @map("color_class") @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@index([status], map: "idx_cat_status")
  @@index([sortOrder], map: "idx_cat_sort")
  @@map("course_categories")
}

model Course {
  id             BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  franchiseId    BigInt?      @map("franchise_id") @db.UnsignedBigInt
  name           String       @db.VarChar(150)
  description    String?      @db.Text
  type           CourseType
  category       String?      @db.VarChar(100)
  baseFee        Decimal     @map("base_fee") @db.Decimal(10, 2)
  durationMonths Int         @map("duration_months")
  status         CourseStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamp
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamp

  franchise      Franchise?  @relation("FranchiseCourses", fields: [franchiseId], references: [id], onDelete: Cascade)
  students       Student[]
  franchiseFees  FranchiseCourseFee[]

  @@index([franchiseId], map: "idx_course_franchise")
  @@index([category], map: "idx_course_category")
  @@map("courses")
}

enum CourseType {
  SILVER
  GOLD
  DIAMOND
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

model FranchiseCourseFee {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  franchiseId BigInt @map("franchise_id") @db.UnsignedBigInt
  courseId   BigInt   @map("course_id") @db.UnsignedBigInt
  customFee  Decimal  @map("custom_fee") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, courseId], map: "unique_franchise_course")
  @@index([courseId], map: "fk_fee_course")
  @@map("franchise_course_fees")
}

model Student {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt        @unique @map("user_id") @db.UnsignedBigInt
  franchiseId BigInt        @map("franchise_id") @db.UnsignedBigInt
  courseId    BigInt        @map("course_id") @db.UnsignedBigInt
  totalFee    Decimal       @map("total_fee") @db.Decimal(10, 2)
  paidFee     Decimal       @default(0.00) @map("paid_fee") @db.Decimal(10, 2)
  admissionDate DateTime     @map("admission_date") @db.Date
  address     String?       @db.VarChar(500)
  area        String?       @db.VarChar(150)
  pincode     String?       @db.VarChar(20)
  city        String?       @db.VarChar(100)
  state       String?       @db.VarChar(100)
  status      StudentStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamp

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  franchise   Franchise     @relation(fields: [franchiseId], references: [id])
  course      Course        @relation(fields: [courseId], references: [id])
  certificates Certificate[]
  feedback    Feedback[]
  payments    Payment[]

  @@index([franchiseId], map: "idx_student_franchise")
  @@index([courseId], map: "idx_student_course")
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Staff {
  id          BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt      @unique @map("user_id") @db.UnsignedBigInt
  franchiseId BigInt     @map("franchise_id") @db.UnsignedBigInt
  salary     Decimal     @db.Decimal(10, 2)
  joiningDate DateTime   @map("joining_date") @db.Date
  status     StaffStatus @default(ACTIVE)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamp

  user       User        @relation(fields: [userId], references: [id])
  franchise Franchise   @relation(fields: [franchiseId], references: [id])

  @@index([franchiseId], map: "idx_staff_franchise")
  @@map("staff")
}

enum StaffStatus {
  ACTIVE
  RESIGNED
}

model Attendance {
  id            BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  userId        BigInt          @map("user_id") @db.UnsignedBigInt
  franchiseId  BigInt          @map("franchise_id") @db.UnsignedBigInt
  attendanceDate DateTime       @map("attendance_date") @db.Date
  status        AttendanceStatus
  method        AttendanceMethod @default(MANUAL)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamp

  user          User            @relation(fields: [userId], references: [id])
  franchise     Franchise       @relation(fields: [franchiseId], references: [id])

  @@unique([userId, attendanceDate], map: "unique_attendance")
  @@index([franchiseId], map: "fk_attendance_franchise")
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AttendanceMethod {
  MANUAL
  FACE_RECOGNITION
}

model Payment {
  id                BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  studentId         BigInt        @map("student_id") @db.UnsignedBigInt
  franchiseId      BigInt        @map("franchise_id") @db.UnsignedBigInt
  amount            Decimal       @db.Decimal(10, 2)
  paymentMode       PaymentMode   @map("payment_mode")
  transactionReference String?    @map("transaction_reference") @db.VarChar(150)
  status            PaymentStatus @default(SUCCESS)
  paymentDate       DateTime?     @map("payment_date") @db.DateTime
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp

  student           Student       @relation(fields: [studentId], references: [id])
  franchise         Franchise     @relation(fields: [franchiseId], references: [id])

  @@index([franchiseId], map: "fk_payment_franchise")
  @@index([studentId], map: "idx_payment_student")
  @@map("payments")
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

model Certificate {
  id              BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  studentId       BigInt            @map("student_id") @db.UnsignedBigInt
  franchiseId    BigInt            @map("franchise_id") @db.UnsignedBigInt
  certificateNumber String          @unique @map("certificate_number") @db.VarChar(100)
  issueDate       DateTime?         @map("issue_date") @db.Date
  status          CertificateStatus @default(REQUESTED)
  issuedBy        BigInt?           @map("issued_by") @db.UnsignedBigInt
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamp

  student         Student           @relation(fields: [studentId], references: [id])
  franchise       Franchise         @relation(fields: [franchiseId], references: [id])
  issuer          User?             @relation("CertificateIssuer", fields: [issuedBy], references: [id])

  @@index([franchiseId], map: "fk_certificate_franchise")
  @@index([studentId], map: "fk_certificate_student")
  @@index([issuedBy], map: "fk_certificate_admin")
  @@map("certificates")
}

enum CertificateStatus {
  REQUESTED
  APPROVED
  ISSUED
  REJECTED
}

model Feedback {
  id          BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  studentId   BigInt          @map("student_id") @db.UnsignedBigInt
  franchiseId BigInt          @map("franchise_id") @db.UnsignedBigInt
  message     String          @db.Text
  response    String?         @db.Text
  status      FeedbackStatus  @default(OPEN)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamp

  student     Student         @relation(fields: [studentId], references: [id])
  franchise   Franchise       @relation(fields: [franchiseId], references: [id])

  @@index([studentId], map: "fk_feedback_student")
  @@index([franchiseId], map: "fk_feedback_franchise")
  @@map("feedback")
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model OtpVerification {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  email     String   @db.VarChar(150)
  otp       String   @db.VarChar(10)
  purpose   String   @db.VarChar(50)
  expiresAt DateTime @map("expires_at") @db.DateTime
  used      Boolean  @default(false) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([email, purpose], map: "idx_otp_email_purpose")
  @@index([expiresAt], map: "idx_otp_expires")
  @@map("otp_verifications")
}

model UserPanelSetting {
  id        Int      @id @default(1)
  config    Json     @db.Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("user_panel_settings")
}

model GlobalSetting {
  id        Int      @id @default(1)
  config    Json     @db.Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("global_settings")
}

model CourseEnrollmentRequest {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  fullName    String   @map("full_name") @db.VarChar(150)
  email       String   @db.VarChar(150)
  phone       String   @db.VarChar(20)
  courseName  String   @map("course_name") @db.VarChar(200)
  message     String?  @db.Text
  address     String?  @db.VarChar(500)
  pincode     String?  @db.VarChar(10)
  area        String?  @db.VarChar(150)
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([createdAt], map: "idx_enrollment_created")
  @@map("course_enrollment_requests")
}

model OfferApplication {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  fullName    String   @map("full_name") @db.VarChar(150)
  email       String   @db.VarChar(150)
  phone       String   @db.VarChar(20)
  offerId     String   @map("offer_id") @db.VarChar(100)
  offerTitle  String   @map("offer_title") @db.VarChar(200)
  message     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([createdAt], map: "idx_offer_app_created")
  @@map("offer_applications")
}

model FranchiseInquiry {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  fullName        String   @map("full_name") @db.VarChar(150)
  email           String   @db.VarChar(150)
  phone           String   @db.VarChar(20)
  city            String?  @db.VarChar(100)
  state           String?  @db.VarChar(100)
  investmentRange String?  @map("investment_range") @db.VarChar(80)
  message         String?  @db.Text
  franchiseId     String?  @map("franchise_id") @db.VarChar(50)
  franchiseName   String?  @map("franchise_name") @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([createdAt], map: "idx_franchise_inquiry_created")
  @@index([franchiseId], map: "idx_franchise_inquiry_franchise")
  @@map("franchise_inquiries")
}

model FranchiseOrder {
  id              BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  orderId         String            @unique @map("order_id") @db.VarChar(100)
  cfOrderId       String?           @map("cf_order_id") @db.VarChar(100)
  fullName        String            @map("full_name") @db.VarChar(150)
  email           String            @db.VarChar(150)
  phone           String            @db.VarChar(20)
  planId          Int               @map("plan_id") @db.UnsignedTinyInt
  planName        String            @map("plan_name") @db.VarChar(50)
  amount          Decimal           @db.Decimal(10, 2)
  status          FranchiseOrderStatus @default(PENDING)
  paymentSessionId String?          @map("payment_session_id") @db.VarChar(500)
  cfPaymentId     String?           @map("cf_payment_id") @db.VarChar(100)
  paymentMode     String?           @map("payment_mode") @db.VarChar(50)
  city            String?           @db.VarChar(100)
  state           String?           @db.VarChar(100)
  address         String?           @db.VarChar(500)
  message         String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamp

  plan            SubscriptionPlan  @relation(fields: [planId], references: [id])

  @@index([email], map: "idx_fo_email")
  @@index([status], map: "idx_fo_status")
  @@map("franchise_orders")
}

enum FranchiseOrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model SupportRequest {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  fullName  String   @map("full_name") @db.VarChar(150)
  email     String   @db.VarChar(150)
  message   String   @db.Text
  source    String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([createdAt], map: "idx_support_created")
  @@map("support_requests")
}

model Announcement {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  title     String   @db.VarChar(200)
  message   String   @db.Text
  createdBy BigInt   @map("created_by") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  creator   User     @relation("AnnouncementCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_announcement_created")
  @@map("announcements")
}


// ── Chat System ──────────────────────────────────────────────────────────────

model ChatRoom {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  /// "direct" = 1-on-1 between superadmin and a franchise admin
  /// "group"  = group discussion room
  type        String    @default("direct") @db.VarChar(20)
  name        String?   @db.VarChar(150)
  /// For direct rooms: comma-separated sorted user IDs (e.g. "1_42")
  slug        String?   @unique @db.VarChar(100)
  createdBy   BigInt    @map("created_by") @db.UnsignedBigInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp

  messages    ChatMessage[]
  members     ChatRoomMember[]

  @@index([type], map: "idx_room_type")
  @@index([slug], map: "idx_room_slug")
  @@map("chat_rooms")
}

model ChatRoomMember {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  roomId    BigInt   @map("room_id") @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  /// last time this user read messages in this room
  lastReadAt DateTime? @map("last_read_at") @db.DateTime
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamp

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], map: "unique_room_member")
  @@index([userId], map: "idx_member_user")
  @@map("chat_room_members")
}

model ChatMessage {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  roomId    BigInt   @map("room_id") @db.UnsignedBigInt
  senderId  BigInt   @map("sender_id") @db.UnsignedBigInt
  body      String   @db.Text
  /// optional: "text" | "image" | "file"
  msgType   String   @default("text") @map("msg_type") @db.VarChar(20)
  fileUrl   String?  @map("file_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt], map: "idx_msg_room_time")
  @@index([senderId], map: "idx_msg_sender")
  @@map("chat_messages")
}
